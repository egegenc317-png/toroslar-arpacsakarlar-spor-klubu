{
  "name": "mahalle-agi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:start": "node scripts/dev-start.cjs",
    "postinstall": "npm run prisma:generate:postgres",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "delete:amator-klub": "powershell -ExecutionPolicy Bypass -File scripts/delete-amator-klub.ps1",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "ts-node --compiler-options {\"module\":\"CommonJS\"} scripts/smoke-test.ts",
    "prisma:generate:all": "prisma generate && prisma generate --schema prisma/schema.postgres.prisma",
    "prisma:generate:postgres": "prisma generate --schema prisma/schema.postgres.prisma",
    "migrate:sqlite-to-postgres": "ts-node --compiler-options {\"module\":\"CommonJS\"} scripts/migrate-sqlite-to-postgres.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1006.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@sentry/nextjs": "^10.43.0",
    "@tanstack/react-query": "^5.62.16",
    "@upstash/redis": "^1.36.4",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "14.2.24",
    "next-auth": "^4.24.11",
    "nodemailer": "^7.0.13",
    "pg": "^8.20.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@prisma/adapter-better-sqlite3": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "better-sqlite3": "^12.6.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.24",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "prisma": "^7.4.2",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  }
}
