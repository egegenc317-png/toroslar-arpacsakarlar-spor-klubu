generator client {
  provider = "prisma-client-js"
  output   = "../generated/postgres-client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String            @id
  name                String
  username            String?           @unique
  email               String            @unique
  emailVerified       DateTime?
  passwordHash        String
  image               String?
  role                String            @default("USER")
  locationScope       String?
  neighborhoodId      String?
  neighborhood        Neighborhood?     @relation(fields: [neighborhoodId], references: [id])
  verifiedAt          DateTime?
  suspendedUntil      DateTime?
  birthDate           DateTime?
  showAge             Boolean           @default(false)
  accountType         String            @default("NEIGHBOR")
  businessCategory    String?
  businessClosedHours String?
  shopName            String?
  shopLogo            String?
  shopLocationText    String?
  shopLocationLat     Float?
  shopLocationLng     Float?
  lastBoardSeenAt     DateTime?
  seenBoardPostIds    String?
  lastActiveAt        DateTime?
  createdAt           DateTime          @default(now())
  listings            Listing[]
  buyerConversations  Conversation[]    @relation("BuyerConversations")
  sellerConversations Conversation[]    @relation("SellerConversations")
  messages            Message[]
  reportsMade         Report[]          @relation("ReporterReports")
  boardPosts          BoardPost[]
  flowPosts           FlowPost[]
  flowLikes           FlowPostLike[]
  polls               Poll[]
  ratingsGiven        UserRating[]      @relation("RatingRater")
  ratingsReceived     UserRating[]      @relation("RatingTarget")
  weeklyUsage         UserWeeklyUsage[]
  auditLogs           AuditLog[]        @relation("AuditActor")
  accounts            Account[]
  sessions            Session[]

  @@index([neighborhoodId])
  @@index([lastActiveAt])
  @@index([createdAt])
}

model Neighborhood {
  id         String      @id
  city       String
  district   String
  name       String
  inviteCode String      @unique
  lat        Float
  lng        Float
  radiusKm   Float       @default(15)
  users      User[]
  listings   Listing[]
  boardPosts BoardPost[]
  flowPosts  FlowPost[]
  polls      Poll[]
}

model Listing {
  id             String         @id
  neighborhoodId String
  neighborhood   Neighborhood   @relation(fields: [neighborhoodId], references: [id])
  userId         String
  user           User           @relation(fields: [userId], references: [id])
  type           String
  title          String
  description    String
  price          Float?
  category       String
  photos         String
  locationHint   String?
  locationText   String?
  locationLat    Float?
  locationLng    Float?
  status         String         @default("ACTIVE")
  adminNote      String?
  viewCount      Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime
  conversations  Conversation[]

  @@index([neighborhoodId, status, createdAt])
  @@index([userId, createdAt])
}

model Conversation {
  id                 String    @id
  listingId          String?
  listing            Listing?  @relation(fields: [listingId], references: [id])
  buyerId            String
  buyer              User      @relation("BuyerConversations", fields: [buyerId], references: [id])
  sellerId           String
  seller             User      @relation("SellerConversations", fields: [sellerId], references: [id])
  conversationType   String    @default("DIRECT")
  contextType        String?
  contextTitle       String?
  groupName          String?
  groupDescription   String?
  groupImage         String?
  participantIds     String?
  adminIds           String?
  createdById        String?
  lastSeenByUser     String?
  pinnedMessageId    String?
  pinnedMessageAt    DateTime?
  pinnedByUserId     String?
  lastSeenByBuyerAt  DateTime?
  lastSeenBySellerAt DateTime?
  createdAt          DateTime  @default(now())
  messages           Message[]

  @@unique([listingId, buyerId, sellerId])
  @@index([buyerId, createdAt])
  @@index([sellerId, createdAt])
  @@index([conversationType, createdAt])
  @@index([contextType, createdAt])
}

model Message {
  id                         String       @id
  conversationId             String
  conversation               Conversation @relation(fields: [conversationId], references: [id])
  senderId                   String
  sender                     User         @relation(fields: [senderId], references: [id])
  body                       String
  viewOnceConsumedByBuyerAt  DateTime?
  viewOnceConsumedBySellerAt DateTime?
  createdAt                  DateTime     @default(now())

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
}

model Report {
  id         String   @id
  reporterId String
  reporter   User     @relation("ReporterReports", fields: [reporterId], references: [id])
  targetType String
  targetId   String
  reason     String
  details    String?
  status     String   @default("OPEN")
  createdAt  DateTime @default(now())

  @@index([status, createdAt])
  @@index([reporterId, createdAt])
}

model BoardPost {
  id             String       @id
  neighborhoodId String
  neighborhood   Neighborhood @relation(fields: [neighborhoodId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  type           String
  title          String
  body           String
  photos         String
  locationText   String?
  locationLat    Float?
  locationLng    Float?
  viewCount      Int          @default(0)
  createdAt      DateTime     @default(now())

  @@index([neighborhoodId, createdAt])
  @@index([userId, createdAt])
}

model FlowPost {
  id             String         @id
  neighborhoodId String
  neighborhood   Neighborhood   @relation(fields: [neighborhoodId], references: [id])
  userId         String
  user           User           @relation(fields: [userId], references: [id])
  body           String
  photos         String
  parentPostId   String?
  parentPost     FlowPost?      @relation("FlowReplies", fields: [parentPostId], references: [id])
  replies        FlowPost[]     @relation("FlowReplies")
  repostOfPostId String?
  repostOfPost   FlowPost?      @relation("FlowReposts", fields: [repostOfPostId], references: [id])
  reposts        FlowPost[]     @relation("FlowReposts")
  likes          FlowPostLike[]
  createdAt      DateTime       @default(now())

  @@index([neighborhoodId, createdAt])
  @@index([userId, createdAt])
  @@index([parentPostId, createdAt])
  @@index([repostOfPostId, createdAt])
}

model FlowPostLike {
  id        String   @id
  postId    String
  post      FlowPost @relation(fields: [postId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([userId, createdAt])
}

model Poll {
  id             String       @id
  neighborhoodId String
  neighborhood   Neighborhood @relation(fields: [neighborhoodId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  question       String
  options        String
  createdAt      DateTime     @default(now())
  votes          PollVote[]

  @@index([neighborhoodId, createdAt])
  @@index([userId, createdAt])
}

model PollVote {
  id          String   @id
  pollId      String
  poll        Poll     @relation(fields: [pollId], references: [id])
  userId      String
  userIdIndex String   @default("")
  optionIndex Int
  createdAt   DateTime @default(now())

  @@index([pollId, createdAt])
  @@index([userIdIndex, createdAt])
}

model UserRating {
  id           String   @id
  raterUserId  String
  rater        User     @relation("RatingRater", fields: [raterUserId], references: [id])
  targetUserId String
  target       User     @relation("RatingTarget", fields: [targetUserId], references: [id])
  score        Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime

  @@index([targetUserId, createdAt])
  @@index([raterUserId, createdAt])
}

model UserWeeklyUsage {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  weekKey   String
  seconds   Int
  createdAt DateTime @default(now())
  updatedAt DateTime

  @@unique([userId, weekKey])
  @@index([weekKey, seconds])
}

model SiteVisit {
  id        String   @id
  visitorId String
  userId    String?
  dateKey   String
  pageCount Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime

  @@unique([visitorId, dateKey])
  @@index([dateKey, createdAt])
  @@index([userId, dateKey])
}

model SitePageView {
  id             String   @id
  visitorId      String
  userId         String?
  neighborhoodId String?
  dateKey        String
  path           String
  viewCount      Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime

  @@unique([visitorId, dateKey, path])
  @@index([dateKey, path])
  @@index([neighborhoodId, dateKey])
  @@index([userId, dateKey])
}

model GroupInvite {
  id              String    @id
  conversationId  String
  tokenHash       String
  tokenCipher     String
  createdByUserId String
  createdAt       DateTime  @default(now())
  expiresAt       DateTime
  revokedAt       DateTime?

  @@index([conversationId, expiresAt])
  @@index([expiresAt, revokedAt])
}

model EmailVerification {
  email      String    @id
  codeHash   String
  expiresAt  DateTime
  verifiedAt DateTime?
  attempts   Int       @default(0)

  @@index([expiresAt, verifiedAt])
}

model RateLimitEntry {
  key         String @id
  count       Int
  windowStart BigInt
}

model AuditLog {
  id          String   @id
  actorUserId String?
  actor       User?    @relation("AuditActor", fields: [actorUserId], references: [id])
  action      String
  targetType  String
  targetId    String?
  meta        String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([actorUserId, createdAt])
  @@index([targetType, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expires])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
